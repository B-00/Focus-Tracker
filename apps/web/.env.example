# Focus Tracker web client — environment configuration
#
# Copy to `.env.local` for local overrides (gitignored).

# Where to send API requests. Leave empty in dev so the Vite proxy
# forwards /v1/... to http://localhost:3000 (see vite.config.ts).
# In production set this to the deployed API origin, e.g. https://api.example.com.
VITE_API_BASE_URL=
