# Focus Tracker API — environment configuration
#
# Copy this file to `.env` and adjust as needed. The `.env` file is gitignored.
# Defaults match the docker-compose.yml at the repo root.

# Postgres connection string (Prisma format).
# Host port 5433 matches docker-compose.yml (5432 is often taken by a
# locally-installed Postgres on dev machines).
DATABASE_URL="postgresql://focus_tracker:dev_password@localhost:5433/focus_tracker?schema=public"

# HTTP server
API_PORT=3000
API_HOST=0.0.0.0

# CORS — comma-separated origins allowed to call the API.
# Web dev server defaults to http://localhost:5173 (Vite).
CORS_ORIGINS="http://localhost:5173"

# JWT secret (Auth.md §7) — replace with `openssl rand -hex 64` output before first use.
JWT_SECRET="change-me-to-a-64-byte-hex-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Node runtime
NODE_ENV=development
