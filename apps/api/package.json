{
  "name": "@focus-tracker/api",
  "version": "0.0.1",
  "private": true,
  "description": "Focus Tracker backend (NestJS + Prisma + Postgres). See PROJECT.md §4.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo \"(api) lint TODO\" && exit 0",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "cli": "ts-node -r tsconfig-paths/register --project tsconfig.json src/cli/main.ts",
    "seed-user": "pnpm cli seed-user",
    "reset-password": "pnpm cli reset-password",
    "list-users": "pnpm cli list-users",
    "post-telemetry": "pnpm cli post-telemetry",
    "cleanup-synthetic": "ts-node -r tsconfig-paths/register --project tsconfig.json scripts/cleanup-synthetic.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@focus-tracker/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@prisma/client": "^6.0.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nest-commander": "^3.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "prisma": "^6.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
