// Focus Tracker — Prisma schema (v1)
//
// Single source of truth for the application database. Mirrors every entity
// listed in PROJECT.md §5 (Data Model) plus the entities defined in the
// individual feature specs. Inline cross-references point back to the spec
// that owns each model's shape and semantics — if a column's purpose isn't
// obvious here, that's the place to look.
//
// Conventions (mirroring PROJECT.md §7.1):
//   * IDs are `cuid()` by default. Exceptions:
//       - Device.id is a UUID generated by the source client at install time.
//       - TelemetryEvent.id is a ULID / UUIDv7 generated client-side at
//         capture time (drives idempotent ingest — see PROJECT.md §12.5).
//   * All timestamps are `DateTime` (Postgres `timestamptz`); the app stores
//     and exchanges UTC and formats locally in the UI.
//   * Date-only fields use `@db.Date` (no time-of-day, no timezone).
//   * Money-like decimals (scores) use `Decimal` with explicit precision.
//   * Cascade deletes from User wipe everything user-scoped. Deleting a
//     Section cascades its tasks (sections are normally soft-archived via
//     `archivedAt`; see Tasks.md §3.1).
//   * Postgres enums are used for finite, app-stable value sets.
//
// Partial unique indexes (Prisma can't express these in pure schema syntax
// for v1 — flagged below with `// MIGRATION:` comments):
//   * FocusSession: at most one row per user with state IN ('running','paused')
//     — see FocusSession.md §3.1. Add as a raw SQL migration step:
//       CREATE UNIQUE INDEX "FocusSession_userId_active_unique"
//         ON "FocusSession" ("userId")
//         WHERE state IN ('running', 'paused');

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
//  ENUMS
// =============================================================================

/// Source client family. Distinguishes browser-origin vs desktop-origin events
/// in `TelemetryEvent`, `ActivityMinuteRollup`, and `Device`. See Sources Markdown/.
enum DeviceSource {
  browser
  desktop
}

/// Wire-protocol event kinds accepted by `POST /v1/telemetry/batch`.
/// See PROJECT.md §12.4 and Sources Markdown/Extension.md §5 + DesktopApp.md §6.
/// (`idle_start` / `idle_end` and `data_gap` were intentionally removed for v1.)
enum TelemetryEventKind {
  focus_change
  heartbeat
  session_start
  session_end
}

/// Task discriminator. Drives which other fields on `Task` are meaningful.
/// See Tasks.md §3.2.
enum TaskKind {
  dated
  ongoing
  routine
}

/// Required on every Task (no default — user must pick at creation).
/// Drives sort order across all surfaces and weights chart scoring.
/// Snapshotted onto `TaskInstance.priority` at materialisation time.
/// Weights live in TaskCharts.md §5.1: extreme=2.0, high=1.5, mid=1.0, low=0.5.
enum TaskPriority {
  low
  mid
  high
  extreme
}

/// Focus Session lifecycle state. Server-driven; client never persists alone.
/// See FocusSession.md §3.1 / §4.
enum FocusSessionState {
  running
  paused
  completed
  aborted
}

/// Picked at session start; immutable for the session's lifetime.
/// See FocusSession.md §3.1.
enum FocusSessionMode {
  timer
  open
}

/// Why a Focus Session ended. Null while running.
/// See FocusSession.md §3.1 / §9.8 (aborted).
enum FocusSessionEndReason {
  timer_complete
  manual_stop
  aborted
}

/// API-key scopes. v1 ships exactly one scope.
/// See Auth.md §10.3.
enum ApiKeyScope {
  telemetry_write
}

// =============================================================================
//  IDENTITY & AUTH
// =============================================================================

/// The single user (v1) with multi-user-ready columns from day one.
/// Owns every other row in the database via FK relationships.
///
/// Sources:
///   * PROJECT.md §5 (User entity overview)
///   * Auth.md §10.1 (email + passwordHash for auth path)
///   * MementoMori.md §3.3 (birthday, lifeExpectancyYears)
///   * Settings.md §6.1 (displayName, timezone, timezoneOverridden)
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String   // argon2id parameterised hash string (Auth.md §7.1)
  displayName         String?
  birthday            DateTime? @db.Date
  lifeExpectancyYears Int       @default(80)
  timezone            String    @default("UTC")  // IANA tz name, e.g. "America/New_York"
  timezoneOverridden  Boolean   @default(false)  // false = auto-detected from browser
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Auth
  refreshTokens   RefreshToken[]
  apiKeys         ApiKey[]
  pairingCodes    PairingCode[]

  // Devices
  devices         Device[]

  // Tasks
  sections        Section[]
  tasks           Task[]

  // Focus Sessions
  focusSessions   FocusSession[]

  // Memento Mori
  milestones      Milestone[]
  weekNotes       WeekNote[]

  // Telemetry / activity
  telemetryEvents       TelemetryEvent[]
  activityMinuteRollups ActivityMinuteRollup[]
  weekActivityMinutes   WeekActivityMinutes[]

  // Scores
  routineSectionDailyScores RoutineSectionDailyScore[]
  datedSectionDailyScores   DatedSectionDailyScore[]

  // Dashboard prefs
  dashboardPrefs  UserDashboardPrefs?

  @@index([email])
}

/// Opaque, hashed refresh tokens issued at login and rotated on each refresh.
/// One row per device-side refresh token; revoked rows are kept for audit
/// until the cleanup job (PROJECT.md §4.4) removes them post-expiry.
///
/// Owner: Auth.md §10.2.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique  // sha256(rawToken), hex — raw token is never persisted
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime              // issuedAt + 30d sliding
  revokedAt  DateTime?
  userAgent  String?               // recorded for future "active sessions" UI
  ip         String?

  @@index([userId, revokedAt])     // "list this user's active sessions"
  @@index([expiresAt])              // nightly cleanup job (PROJECT.md §4.4)
}

/// Long-lived per-device API keys used by source clients (browser ext, desktop
/// daemon) on `POST /v1/telemetry/batch`. Raw key has shape `ft_live_<base64>`
/// and is shown to the device exactly once at pairing; only the sha256 hash
/// is persisted server-side.
///
/// Owner: Auth.md §10.3.
model ApiKey {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Must match Device.id type — uuid, not the default text. FK constraint
  // will not link otherwise (the two columns become "incompatible types").
  deviceId   String       @unique @db.Uuid           // exactly one key per device
  device     Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tokenHash  String       @unique  // sha256(rawToken), hex
  scope      ApiKeyScope  @default(telemetry_write)
  createdAt  DateTime     @default(now())
  revokedAt  DateTime?

  @@index([userId, revokedAt])
}

/// Short-lived 6-digit pairing codes used to bind a new source client to the
/// user's account. The client proposes its device metadata, the user types
/// the 6 digits into the web app, and on successful claim the server creates
/// the `Device` row and issues the corresponding `ApiKey`.
///
/// Owner: Auth.md §10.4.
model PairingCode {
  id              String    @id @default(cuid())
  code            String    @unique  // 6 numeric digits, server-generated
  /// JSON shape: { deviceId: string (UUID, client-proposed), source: 'browser' | 'desktop',
  ///               platform: string, label: string, clientVersion: string }
  deviceProposal  Json
  claimedByUserId String?
  claimedByUser   User?     @relation(fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt       DateTime?
  /// Plaintext API key, populated atomically when the user claims the code,
  /// returned to the polling device exactly once, then the row is deleted.
  /// Lives in the DB for a few seconds at most (claim → next 3s poll). This
  /// is the only place in the schema where raw secret material is stored —
  /// see Auth.md §5.1 step 4 for the lifecycle. Hash of the same value
  /// lives permanently in `ApiKey.tokenHash`.
  mintedApiKey    String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime              // createdAt + 5 min

  @@index([expiresAt])                  // cleanup job (PROJECT.md §4.4)
}

/// A paired source client (one browser install or one desktop daemon).
/// `id` is a UUID generated client-side at install time, then claimed during
/// pairing — keeping it stable across re-pairings on the same machine.
///
/// Sources:
///   * PROJECT.md §5 (Device entity overview)
///   * Settings.md §6.2 (label, lastSeen / lastSuccessfulIngestAt — inline diagnostics)
///   * Sources Markdown/Extension.md §4 and DesktopApp.md §4 (pairing flow)
model Device {
  id                      String       @id @db.Uuid              // client-generated UUID
  userId                  String
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  source                  DeviceSource
  label                   String                                   // user-editable in Settings → Devices
  platform                String?                                  // e.g. "macOS 14.4", "Firefox 126"
  clientVersion           String?                                  // semver of the source client
  pairedAt                DateTime     @default(now())
  lastSeen                DateTime?                                // last time we got any request from this device
  lastSuccessfulIngestAt  DateTime?                                // last 2xx response to a telemetry batch
  createdAt               DateTime     @default(now())

  apiKey                  ApiKey?
  telemetryEvents         TelemetryEvent[]

  @@index([userId])
}

// =============================================================================
//  TASKS
// =============================================================================

/// User-defined container for tasks. Soft-archived via `archivedAt` — hard
/// delete is allowed but rarely the right call.
///
/// Owner: Tasks.md §3.1.
model Section {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String    // 1..60
  color      String    @default("#9ca3af") // hex, neutral default
  position   Int       @default(0)         // manual ordering in the UI
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  tasks                    Task[]
  routineDailyScores       RoutineSectionDailyScore[]
  datedDailyScores         DatedSectionDailyScore[]

  @@index([userId, position])
  @@index([userId, archivedAt])
}

/// A unit of work, kind-discriminated. Per-kind validation lives in the
/// service layer — see Tasks.md §3.2 ("Per-kind rules") for the exact matrix.
/// `sectionId = NULL` means the implicit Inbox (Tasks.md §3.4).
///
/// Owner: Tasks.md §3.2.
model Task {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionId            String?
  section              Section?      @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  kind                 TaskKind
  priority             TaskPriority   // REQUIRED, no default — service enforces (Tasks.md §3.6)
  title                String         // 1..200
  description          String?        @db.Text

  // Dated-only
  startDate            DateTime?      @db.Date
  endDate              DateTime?      @db.Date

  // Dated + ongoing: completion timestamp (routines complete on TaskInstance)
  completedAt          DateTime?

  // Routine-only
  routineDaysOfWeek    Int[]          // ISO weekday subset of [1..7], Mon=1
  routineStartDate     DateTime?      @db.Date
  routineEndDate       DateTime?      @db.Date

  // Transfer / backlog (dated single-day only)
  transferIfMissed     Boolean        @default(false)
  transferredFromDate  DateTime?      @db.Date
  inBacklog            Boolean        @default(false)

  archivedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  instances            TaskInstance[]
  focusSessions        FocusSession[]

  @@index([userId, kind])
  @@index([userId, startDate])           // calendar / today queries
  @@index([userId, inBacklog])           // backlog panel
  @@index([sectionId, kind])             // /tasks per-section grouping
}

/// One row per scheduled occurrence of a routine. Lazily materialised on read
/// for today; the nightly job back-fills all missing past days (so "missed"
/// is a real row with `completedAt = null`, not the absence of a row).
///
/// `priority` is a snapshot of the parent routine's priority at materialisation
/// time — editing the parent's priority does NOT rewrite history (Tasks.md §3.6).
///
/// Owner: Tasks.md §3.3.
model TaskInstance {
  id            String        @id @default(cuid())
  taskId        String
  task          Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  scheduledDate DateTime      @db.Date
  priority      TaskPriority   // snapshot at materialisation; drives chart weighting
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([taskId, scheduledDate])
  @@index([scheduledDate])               // nightly maintenance scans by day
}

// =============================================================================
//  FOCUS SESSIONS
// =============================================================================

/// User-controlled focus window. Telemetry remains always-on regardless of
/// session state; a running session simply causes the ingest path to stamp
/// `focusSessionId` onto any event whose window overlaps the session.
///
/// Constraint: at most one session per user where state ∈ {running, paused}.
/// MIGRATION: enforce with a partial UNIQUE INDEX (see file header).
///
/// Owner: FocusSession.md §3.1.
model FocusSession {
  id                  String                  @id @default(cuid())
  userId              String
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId              String?
  task                Task?                   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  mode                FocusSessionMode
  plannedDurationMs   Int?                    // required when mode=timer
  state               FocusSessionState
  startedAt           DateTime
  endedAt             DateTime?
  effectiveDurationMs Int?                    // (endedAt - startedAt) - Σ pauses
  endReason           FocusSessionEndReason?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  pauses              FocusSessionPause[]
  telemetryEvents     TelemetryEvent[]

  @@index([userId, state])                    // "current active session" lookup (hot path)
  @@index([userId, startedAt])                // session history list
  @@index([taskId])                           // "sessions for this task"
}

/// One row per Pause/Resume cycle inside a Focus Session. The `trigger` column
/// was intentionally omitted in v1 (auto-pause was cut — every pause is
/// user-initiated; FocusSession.md §6 stub explains).
///
/// Owner: FocusSession.md §3.2.
model FocusSessionPause {
  id         String       @id @default(cuid())
  sessionId  String
  session    FocusSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pausedAt   DateTime
  resumedAt  DateTime?                          // null while still paused
  durationMs Int?                               // resumedAt - pausedAt, set on resume

  @@index([sessionId])
}

// =============================================================================
//  MEMENTO MORI
// =============================================================================

/// User-defined annotation on a specific week of the life calendar.
/// `targetDate` is resolved to a week-index at read time using the user's
/// `birthday`.
///
/// Owner: MementoMori.md §3.4.
model Milestone {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetDate DateTime @db.Date
  label      String   // 1..60
  color      String   // hex
  icon       String?  // optional Lucide icon name
  createdAt  DateTime @default(now())

  @@index([userId, targetDate])
}

/// A short plain-text reflection for one past week (week-index from birthday).
/// Notes are only writable for past weeks — today's week becomes writable as
/// soon as today passes (enforced at the service layer).
///
/// Owner: MementoMori.md §3.5.
model WeekNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekIndex Int                              // since-birthday week number
  body      String   @db.Text                // 0..2000
  updatedAt DateTime @updatedAt

  @@unique([userId, weekIndex])
}

// =============================================================================
//  TELEMETRY (raw ingest)
// =============================================================================

/// One row per discrete activity event ingested from a source client.
/// `id` is generated CLIENT-SIDE (ULID / UUIDv7) so that retried batches
/// are idempotent — see PROJECT.md §7.8 / §12.5.
///
/// `target` is a heterogeneous JSON blob:
///   * browser focus_change: { domain: string, url?: string, title?: string }
///   * desktop focus_change: { appName: string, appBundleId?: string, windowTitle?: string }
///   * heartbeat:            { ... } (source-defined; usually a thin echo)
///   * session_start/end:    { sessionId: string }
///
/// `focusSessionId` is stamped server-side at ingest time per FocusSession.md §7.
///
/// Owner: PROJECT.md §12.4 + §12.5.
model TelemetryEvent {
  id              String              @id                          // client-supplied ULID / UUIDv7
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Nullable + SetNull so revoking a device (Settings.md §4.4) preserves
  // historical telemetry for Activity views — only the per-device attribution
  // is lost. User-level cascade still wipes everything when the user is deleted.
  deviceId        String?             @db.Uuid
  device          Device?             @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  source          DeviceSource
  kind            TelemetryEventKind
  target          Json
  startedAt       DateTime
  endedAt         DateTime?
  durationMs      Int?                                                // computed or sent by source

  focusSessionId  String?
  focusSession    FocusSession?       @relation(fields: [focusSessionId], references: [id], onDelete: SetNull)

  clientVersion   String                                              // semver of the source client at capture time
  ingestedAt      DateTime            @default(now())

  @@index([userId, startedAt])                                        // /activity range scans
  @@index([userId, focusSessionId])                                   // post-session breakdown
  @@index([deviceId, startedAt])                                      // per-device diagnostics, while deviceId is still set
}

// =============================================================================
//  AGGREGATES (read-side rollups + precomputed scores)
// =============================================================================

/// 1-minute bucket rollup: how many ms of activity the user had on
/// `(source, target)` during minute `minuteBucket`.
///
/// Maintained as a cheap UPSERT during ingest (PROJECT.md §4.3); read by
/// every "activity over a range" surface: /activity, dashboard widget,
/// Memento Mori weekly shading, etc. (Activity.md §3.2).
///
/// `target` is a flat string here (not JSON) — denormalised at ingest from
/// the rich event target into a stable, display-ready key per source:
///   * browser: the domain (e.g. "github.com")
///   * desktop: the app name (e.g. "Cursor")
model ActivityMinuteRollup {
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  source       DeviceSource
  target       String
  minuteBucket DateTime                                                // truncated to the minute, UTC
  durationMs   Int

  @@id([userId, source, target, minuteBucket])
  @@index([userId, minuteBucket])                                      // range scans across all targets
  @@map("activity_minute_rollup")
}

/// Per-week summary for the Memento Mori life grid base layer.
/// `weekIndex` is the week-since-birthday index (matches Milestone /
/// WeekNote indexing). Refreshed by the nightly maintenance job
/// (PROJECT.md §4.4) for the current and previous weeks; older weeks are
/// effectively immutable.
///
/// Owner: MementoMori.md §6.2.
model WeekActivityMinutes {
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekIndex    Int
  totalMinutes Int                                                     // SUM(activity_minute_rollup.durationMs) / 60_000
  hasSessions  Boolean                                                 // overlay flag for the grid (any completed session that week?)
  computedAt   DateTime @default(now())

  @@id([userId, weekIndex])
  @@map("week_activity_minutes")
}

/// Per-day per-section routine score. Composite PK on (sectionId, date) so a
/// range scan for the Section's chart series is a single index lookup.
///
/// Range: `score ∈ [-1.000, +2.000]`. Equals `baseScore` (routines have no
/// backlog penalty). See TaskCharts.md §5.4.
model RoutineSectionDailyScore {
  sectionId       String
  section         Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date

  scheduledCount  Int                                                   // base-score denominator
  completedCount  Int
  scheduledWeight Decimal  @db.Decimal(6, 2)                            // informational ("max if all done")
  completedWeight Decimal  @db.Decimal(6, 2)                            // base-score numerator
  score           Decimal  @db.Decimal(4, 3)
  runningTotal    Decimal  @db.Decimal(10, 3)
  computedAt      DateTime @default(now())

  @@id([sectionId, date])
  @@index([userId, date])                                               // /charts/routine/global aggregation
  @@map("routine_section_daily_score")
}

/// Per-day per-section dated-family score. Adds backlog-penalty columns on
/// top of the routine shape — see TaskCharts.md §5.4 for column purposes and
/// §5.3 for the geometric-decay penalty formula.
///
/// Range: `score ∈ approximately [-4.000, +2.000]`.
model DatedSectionDailyScore {
  sectionId          String
  section            Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date               DateTime      @db.Date

  scheduledCount     Int                                                   // base-score denominator
  completedCount     Int
  scheduledWeight    Decimal       @db.Decimal(6, 2)                       // informational
  completedWeight    Decimal       @db.Decimal(6, 2)                       // base-score numerator

  backlogCount       Int                                                   // tasks entering Backlog tonight
  backlogTopPriority TaskPriority?                                          // max priority in the backlog set; null when backlogCount=0

  baseScore          Decimal       @db.Decimal(4, 3)                       // [-1.000, +2.000]
  backlogPenalty     Decimal       @db.Decimal(4, 3)                       // (-3.000, 0.000]
  score              Decimal       @db.Decimal(5, 3)                       // baseScore + backlogPenalty
  runningTotal       Decimal       @db.Decimal(10, 3)
  computedAt         DateTime      @default(now())

  @@id([sectionId, date])
  @@index([userId, date])                                                  // /charts/dated/global aggregation
  @@map("dated_section_daily_score")
}

// =============================================================================
//  DASHBOARD PREFS
// =============================================================================

/// Per-user dashboard customisation. No row is created on user signup —
/// the API merges with code-side defaults on read. See Dashboard.md §9.
model UserDashboardPrefs {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetOrder      String[]                                              // widget IDs in render order
  hiddenWidgets    String[]                                              // subset of widgetOrder
  collapsedWidgets String[]                                              // subset of widgetOrder
  updatedAt        DateTime @updatedAt
}
